@using AlAfkarERP.Shared.Utilities
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.IdentityModel.JsonWebTokens
@using SharedWithUI.Auth.Dtos


@inject SharedDataService SharedDataService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<!---->
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-3">

    <!-- Left -->
    <div class="d-flex align-items-center">
        @* <button class="btn btn-light me-2">
            <i class="bi bi-list"></i>
        </button> *@
        <button class="btn btn-light me-2 d-lg-none" @onclick="() => OnToggleSidebar.InvokeAsync()">
            <i class="bi bi-list"></i>
        </button>
        <span class="fw-semibold">Dashboard</span>
    </div>

    <!-- Right -->
    <div class="ms-auto d-flex align-items-center">

        <!--Language-->
        <button @onclick="async () => { await SharedDataService.UpdateLanguageAsync(); }" class="btn btn-light me-2">
            @(SharedDataService.Language == "Ar" ? "Eng" : "ع") <i class="bi bi-globe"></i>
        </button>

        <!-- Search

        <input class="form-control form-control-sm me-3"
               style="width: 200px;"
               placeholder="Search..." />
        -->
        <!-- Notifications -->
        <button class="btn btn-light me-2">
            <i class="bi bi-bell"></i>
        </button>

        <!-- User -->
        <div class="dropdown">
            <button class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown">
                Admin
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item">Profile</a></li>
                <li><a @onclick='async()=>{await ((CustomAuthStateProvider)AuthenticationStateProvider).NotifyUserLogout(); NavigationManager.NavigateTo("/",true);}' class="dropdown-item">Logout</a></li>
            </ul>
        </div>

    </div>

</nav>





@if (1 == 3)
{
    
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">Alafkar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                @if (1 == 10)
                {
                
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="#">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Link</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Dropdown
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#">Action</a></li>
                                <li><a class="dropdown-item" href="#">Another action</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#">Something else here</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link disabled" aria-disabled="true">Disabled</a>
                        </li>
                    </ul>
                }

                <button class="btn btn-light me-2" @onclick="async () => await SharedDataService.UpdateLanguageAsync()">
                    @* <i class="bi bi-bell"></i>  *@
                    @(SharedDataService.Language == "Ar" ? "Eng" : "Ar")
                </button>
                    
                <form class="d-flex">
                    @if (AuthState != null && AuthState.User.Identity.IsAuthenticated)
                    {
            
                        <button class="btn btn-light me-2">
                            <i class="bi bi-bell"></i>
                        </button>
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown">
                                @(AuthState.User?.Claims?.FirstOrDefault(c => c.Type == ClaimTypes.Name)?.Value ?? "")
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item">Profile</a></li>
                                <li><a class="dropdown-item">Logout</a></li>
                                @if (AuthState!.User!.Claims.Any(c => c.Type == JwtRegisteredClaimNames.Typ && c.Value == UserType.SystemUser.ToString()))
                                {
                                    <li><a href="/AdminDashboard" class="dropdown-item">@SharedDataService.SelectViewLang("Dashboard", "لوحة التحكم")</a></li>
                                    @* NavigationManager.NavigateTo("/AdminDashboard"); *@
                                    @* return; *@
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <button type="button" class="btn btn-light me-2" @onclick="OnLogin">
                            <i class="bi bi-key"></i> Login
                        </button>
    
                    }

                    @* <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search" />
                <button class="btn btn-outline-success" type="submit">Search</button> *@
                </form>
            </div>
        </div>
    </nav>

}


@code {
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    private AuthenticationState AuthState;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            AuthState = await ((CustomAuthStateProvider)AuthenticationStateProvider).GetAuthenticationStateAsync();
            // if (!AuthState.User.Identity.IsAuthenticated)
            // {
            //     NavigationManager.NavigateTo("login");
            // }
            // NavigationManager.NavigateTo("/login");
            await InvokeAsync(StateHasChanged);
        }
    }
    protected override void OnInitialized()
    {
        SharedDataService.OnChange1 += HandleChangeAsync;
    }

    private async Task HandleChangeAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SharedDataService.OnChange1 -= HandleChangeAsync;
    }

    public void OnLogin()
    {
        NavigationManager.NavigateTo("/login");
    }
}