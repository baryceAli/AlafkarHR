@using AlAfkarERP.Shared.Utilities
@inject SharedDataService SharedDataService
@inject NavigationManager NavigationManager


<div class="sidebar-premium d-flex flex-column">

    <!-- Logo -->
    <div class="p-4 text-center border-bottom border-secondary border-opacity-10">
        <h5 class="brand-text mb-0">ALAFKAR</h5>
    </div>

    <!-- Menu -->
    <ul class="nav flex-column p-3">

        <li class="nav-item mb-2">
            <NavLink href="/" class="nav-link sidebar-link" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2 me-2"></i> Home
            </NavLink>
        </li>

        <li class="nav-item mb-2">
            <NavLink href="/Organization/Company/List" class="nav-link sidebar-link">
                <i class="bi bi-diagram-3 me-2"></i>
                @(SharedDataService.SelectViewLang("Organization", "الهيكل"))
            </NavLink>
        </li>

        <li class="nav-item mb-2">
            <NavLink href="/Employee/Dashboard" class="nav-link sidebar-link">
                <i class="bi bi-people me-2"></i>
                @(SharedDataService.SelectViewLang("Employees", "الموظفين"))
            </NavLink>
        </li>

    </ul>

</div>