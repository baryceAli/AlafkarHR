@layout AdminLayout
@page "/Employee/Position/List"

@using AlAfkarERP.Shared.Pages.Features.Employees.Services
@using AlAfkarERP.Shared.Pages.Reuable2
@using AlAfkarERP.Shared.Utilities
@using Microsoft.AspNetCore.Components.Authorization
@using SharedWithUI.Employees.Dtos
@using SharedWithUI.Permissions


@inject IPositionService PositionService
@inject ToastService ToastService
@inject ModalService ModalService

@inject AuthenticationStateProvider AuthenticationStateProvider


@inject NavigationManager NavigationManager
@inject SharedDataService SharedDataService


@if (!AuthState.User.Claims.Any(c => c.Value == PermissionList.PositionPermissions.View))
{
    <div class="alert alert-warning">
        <span>@SharedDataService.SelectViewLang("You don't have permissions to view this page", "ليس لديك الصلاحيات لعرض هذه الصفحة")</span>
    </div>
    return;
}

<!-- Branches -->
<h5>@SharedDataService.SelectViewLang("Positions Management", "ادارة الموقع الوظيفي")</h5>

@* <button class="btn btn-sm btn-primary mb-2" @onclick="CreateNew">+ Add Branch</button> *@
<button class="btn btn-primary mb-3"
        @onclick="CreateNew"
        disabled=@(!AuthState.User.Claims.Any(c => c.Value == $"{PermissionList.PositionPermissions.Create}") ? true : false)>
    <i class="bi bi-file-earmark-plus-fill"></i> @(SharedDataService.Language == "Ar" ? "إضافة جديد" : "Create New")
</button>

<div class="card p-3 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <!--

        Export to xls and pdf
        <div class="d-flex gap-2">

            <button class="btn btn-success btn-sm" @onclick="ExportToExcel">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </button>

            <button class="btn btn-danger btn-sm" @onclick="ExportToPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </button>

        </div>
        -->
        <!-- 🔍 Search -->
        <div>
            <input class="form-control"
                   placeholder="Search..."
                   @bind="searchText" />
        </div>

        <!--

        🎯 Filter
        <div class="col-md-3">
            <select class="form-select" @bind="filterMainBranch">
                <option value="">All</option>
                <option value="true">Main Branch</option>
                <option value="false">Not Main</option>
            </select>
        </div>
        -->
        <!-- 📄 Page Size -->
        <div>
            @* <select class="form-select" @bind="pageSize"> *@
            <select class="form-select" @onchange="OnPageSizeChanged">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

    </div>
    <table class="table">
        <thead>
            <tr>
                <th @onclick="() => Sort(nameof(PositionDto.Title))">
                    <span class="@(sortAscending ? "bi bi-arrow-up" : "bi bi-arrow-down")"></span>
                    @SharedDataService.SelectViewLang("Title", "المسمى الوظيفي")
                </th>
                <th @onclick="() => Sort(nameof(PositionDto.TitleEng))">
                    <span class="@(sortAscending ? "bi bi-arrow-up" : "bi bi-arrow-down")"></span>
                    @SharedDataService.SelectViewLang("Title Eng", "المسمى الوظيفي بالانجليزية")
                </th>
                <th @onclick="() => Sort(nameof(PositionDto.BaseSalary))">@SharedDataService.SelectViewLang("Base Salary", "الراتب الاساسي")</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (editingPositionId != null)
            {
                var position = positions.FirstOrDefault(p => p.Id == editingPositionId);
                <tr>
                    <td colspan="4">
                        <EditForm Model="position" OnValidSubmit="() => SavePosition(position)">
                            <DataAnnotationsValidator />
                            <div class="row bg-info-subtle p-3">

                                    

                                <div class="mb-3 row">
                                    <label for="inputFirstName" class="col-sm-2 col-form-label">@SharedDataService.SelectViewLang("Title", "المسمى الوظيفي")</label>
                                    <div class="col-sm-10">
                                        <InputText class="form-control" @bind-Value="position.Title" />
                                        <ValidationMessage For="() => position.Title" />
                                    </div>
                                </div>

                                <div class="mb-3 row">
                                    <label for="inputFirstName" class="col-sm-2 col-form-label">@SharedDataService.SelectViewLang("Title (En)", "المسمى الوظيفي (انجليزي)")</label>
                                    <div class="col-sm-10">
                                        <InputText class="form-control" @bind-Value="position.TitleEng" />
                                        <ValidationMessage For="() => position.TitleEng" />
                                         
                                    </div>
                                </div>


                                <div class="mb-3 row">
                                    <label for="inputFirstName" class="col-sm-2 col-form-label">@SharedDataService.SelectViewLang("BaseSalary", "الراتب الأساسي")</label>
                                    <div class="col-sm-10">
                                        <InputNumber class="form-control" @bind-Value="position.BaseSalary" />
                                        <ValidationMessage For="() => position.BaseSalary" />
                                    </div>
                                </div>


                                    
                                <div class="mb-3 row">
                                    <label for="inputFirstName" class="col-sm-2 col-form-label"></label>
                                    <div class="col-sm-10">
                                    
                                        <button type="submit" class="btn btn-success btn-sm">@SharedDataService.SelectViewLang("Save", "حفظ")</button>
                                        <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">@SharedDataService.SelectViewLang("Cancel", "إلغاء")</button>
                                            
                                    </div>
                                </div>


                            </div>
                        </EditForm>
                    </td>
                </tr>
            }
            @foreach (var position in ProcessedBranches.Where(p => p.Id != editingPositionId))
            {

                
                <tr>
                    <td>@position.Title</td>
                    <td>@position.TitleEng</td>
                    <td>@position.BaseSalary</td>
                    <td>
                        <button class="btn btn-warning btn-sm"
                                @onclick="() => EditPosition(position.Id)"
                                disabled=@(!AuthState.User.Claims.Any(c => c.Value == PermissionList.PositionPermissions.Edit))>
                            @SharedDataService.SelectViewLang("Edit", "تعديل")
                        </button>
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => DeletePosition(position)"
                                disabled=@(!AuthState.User.Claims.Any(c => c.Value == PermissionList.PositionPermissions.Delete))>
                            @SharedDataService.SelectViewLang("Delete", "حذف")
                        </button>
                    </td>
                </tr>

                
            }
        </tbody>
    </table>
    <div class="d-flex justify-content-end align-items-center mt-3">

        <button class="btn btn-sm btn-secondary"
                @onclick="PrevPage"
                disabled="@(pageIndex == 0)">
            Previous
        </button>

        <span class="mx-3">Page @(pageIndex + 1) of @TotalPages @(TotalPages == 1 ? "" : "Pages")</span>

        <button class="btn btn-sm btn-secondary"
                @onclick="NextPage"
                disabled="@(pageIndex >= TotalPages)">
            Next
        </button>

    </div>
</div>

@code {
    private List<PositionDto> positions = new();
    private Guid? editingPositionId;
    private Guid companyId;
    private AuthenticationState AuthState;
    protected override async Task OnInitializedAsync()
    {
        AuthState = await ((CustomAuthStateProvider)AuthenticationStateProvider).GetAuthenticationStateAsync();
        companyId = Guid.Parse(AuthState.User.Claims.First(c => c.Type == "company_id").Value);

        await LoadPositions();
        // var branchResponse = await BranchService.GetByCompanyIdAsync(companyId);
        // if (branchResponse.IsSuccess)
        // {
        //     branches = branchResponse.Data?.ToList() ?? [];
        // }
    }

    void CreateNew()
    {
        var newItem = new PositionDto
        {
            Id = Guid.Empty // IMPORTANT FIX
        };

        positions.Insert(0, newItem);
        editingPositionId = newItem.Id;
    }


    void EditPosition(Guid id) => editingPositionId = id;

    async Task SavePosition(PositionDto p)
    {
        if (p.Id == Guid.Empty)
        {
            Random rnd = new Random();
            p.Code = p.Title.Substring(0, 1) + rnd.Next(100, 999);
            p.CompanyId = companyId;

            var bResponse = await PositionService.CreateAsync(p);
            if (bResponse.IsSuccess)
            {
                //show success
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Position has been created successfully", "تم انشاء الموقع الوظيفي بنجاح"),
                    Type = "success"
                });

            }
            else
            {
                // how fail
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Error has occured, please try again later", "حدث خطأ، الرجاء المحاولة مرة أخرى"),
                    Type = "error"
                });
            }
        }
        else
        {

            var bresponse = await PositionService.UpdateAsync(p);
            if (bresponse.IsSuccess)
            {
                //show success
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Position has been Edited successfully", "تم تعديل الموقع الوظيفي بنجاح"),
                    Type = "success"
                });
            }
            else
            {
                // show  fail
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Error has occured, please try again later", "حدث خطأ، الرجاء المحاولة مرة أخرى"),
                    Type = "error"
                });
            }
        }

        await LoadPositions();
        // var response = await BranchService.GetByCompanyIdAsync(companyId);
        // if (response.IsSuccess)
        // {
        //     branches = response.Data?.ToList() ?? [];
        // }
        editingPositionId = null;
    }

    async Task DeletePosition(PositionDto position)
    {
        await ModalService.ShowAsync(new ModalOptions
        {
            Title = SharedDataService.SelectViewLang("Confirm Delete", "تأكيد عملية الحذف"),
            Message = SharedDataService.SelectViewLang($"Are you sure you want to delete this Position: {position.Title}?",
                                                        $"هل ترغب فعلا في حذف المسمى الوظيفي: {position.Title}؟"),
            ShowCancel = true,
            OkText = SharedDataService.SelectViewLang("Yes", "نعم"),
            CancelText = SharedDataService.SelectViewLang("No", "لا"),

            OnOk = async () =>
            {
                var brResponse = await PositionService.DeleteAsync(position.Id);
                if (brResponse.IsSuccess)
                {

                    ToastService.Show(new ToastMessage
                    {
                        Message = SharedDataService.SelectViewLang("Deleted successfully", "تم الحذف بنجاح"),
                        Type = "success"
                    });

                    await LoadPositions();
                    await InvokeAsync(StateHasChanged);
                    // var response = await BranchService.GetByCompanyIdAsync(companyId);
                    // if (response.IsSuccess)
                    // {
                    //     branches = response.Data?.ToList() ?? [];
                    //     await InvokeAsync(StateHasChanged);
                    // }
                }
                else
                {
                    ToastService.Show(new ToastMessage
                    {
                        Message = SharedDataService.SelectViewLang("Fail to delete the position", "فشلت عملية الحذف"),
                        Type = "error"
                    });
                }


            }
        });


    }


    async Task CancelEdit()
    {
        var item = positions.FirstOrDefault(x => x.Id == editingPositionId);

        if (item != null && item.Id != Guid.Empty)
        {
            // optional: reload from DB if needed

        }

        if (item != null && item.Id != Guid.Empty)
        {
            // existing record → keep it
            var posRes = await PositionService.GetAsync(companyId, 0, 1000);
            if (posRes.IsSuccess)
            {
                positions = posRes.Data?.Data?.ToList() ?? [];
            }
        }
        else
        {
            // new record → remove it
            positions.Remove(item);
        }

        editingPositionId = null;
    }

    #region Table Helpers


    // Searching
    private string searchText = "";

    // Sorting
    private string sortColumn = nameof(PositionDto.Title);
    private bool sortAscending = true;

    // Pagination
    private int pageSize = 5;
    private int pageIndex = 0;
    private async Task LoadPositions()
    {
        // var request = new PaginationRequest(pageIndex, pageSize, searchText);

        var response = await PositionService.GetAsync(companyId, pageIndex, pageSize);//,searchText);

        if (response.IsSuccess)
        {
            // var result = response.Data!.Data;

            // branches = result.Data.ToList();
            positions = response.Data?.Data.ToList() ?? [];
            // TotalPages = (int)response.Data!.Count;
            TotalPages = (int)Math.Ceiling(response.Data!.Count / (double)pageSize);
        }
    }
    async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        pageSize = int.Parse(e.Value!.ToString()!);
        pageIndex = 0;
        await LoadPositions();
    }
    private IEnumerable<PositionDto> ProcessedBranches =>
    positions
        // 🔍 Search
        .Where(b =>
            string.IsNullOrWhiteSpace(searchText) ||
            (b.Title?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (b.Code?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        )


        // 🎯 Filter
        // .Where(b =>
        //     filterMainBranch == null || b.IsMainBranch == filterMainBranch
        // )

        // 🔃 Sorting
        .OrderByDynamic(sortColumn, sortAscending);

        // 📄 Pagination
        // .Skip((pageIndex) * pageSize)
        // .Take(pageSize);



    // Filtering example
    private bool? filterMainBranch = null;
    // private long totalCount = 0;
    private int TotalPages = 1;
    // private int TotalPages =>
    // (int)Math.Ceiling(
    //     totalCount/ (double)pageSize);

    async Task NextPage()
    {
        // if (currentPage < TotalPages)
        //     currentPage++;

        if (pageIndex < TotalPages - 1)
        {
            pageIndex++;
            await LoadPositions();
        }
    }

    async Task PrevPage()
    {
        // if (pageIndex > 1)
        //     pageIndex--;
        
        if (pageIndex > 0)
        {
            pageIndex--;
            await LoadPositions();
        }
    }

    void Sort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }
    #endregion Table helpers

    protected override void OnInitialized()
    {
        SharedDataService.OnChange1 += HandleChangeAsync;
    }

    private async Task HandleChangeAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SharedDataService.OnChange1 -= HandleChangeAsync;
    }
}
