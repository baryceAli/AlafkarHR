@layout EmployeeLayout
@page "/Employee/Specialization/List"
@using AlAfkarERP.Shared.Pages.Features.Employees.Layout


@using AlAfkarERP.Shared.Pages.Features.Employees.Services
@using AlAfkarERP.Shared.Pages.Features.Organization.Pages.Administrations
@using AlAfkarERP.Shared.Pages.Reuable2
@using AlAfkarERP.Shared.Utilities
@using Microsoft.AspNetCore.Components.Authorization
@using SharedWithUI.Employees.Dtos
@using SharedWithUI.Permissions


@inject ISpecializationService SpecializationService
@inject ToastService ToastService
@inject ModalService ModalService

@inject AuthenticationStateProvider AuthenticationStateProvider


@inject NavigationManager NavigationManager
@inject SharedDataService SharedDataService


<!-- Branches -->
<h5>@SharedDataService.SelectViewLang("Specialization Management", "ادارة التخصص العلمي")</h5>

@* <button class="btn btn-sm btn-primary mb-2" @onclick="CreateNew">+ Add Branch</button> *@
<button class="btn btn-primary mb-3"
        @onclick="CreateNew"
        disabled=@(!AuthState.User.Claims.Any(c => c.Value == $"{PermissionList.SpecializationPermissions.Create}") ? true : false)>
    <i class="bi bi-file-earmark-plus-fill"></i> @(SharedDataService.Language == "Ar" ? "إضافة جديد" : "Create New")
</button>

<div class="card p-3 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <!--

        Export to xls and pdf
        <div class="d-flex gap-2">

            <button class="btn btn-success btn-sm" @onclick="ExportToExcel">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </button>

            <button class="btn btn-danger btn-sm" @onclick="ExportToPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </button>

        </div>
        -->
        <!-- 🔍 Search -->
        <div>
            <input class="form-control"
                   placeholder="Search..."
                   @bind="searchText" />
        </div>

        <!--

        🎯 Filter
        <div class="col-md-3">
            <select class="form-select" @bind="filterMainBranch">
                <option value="">All</option>
                <option value="true">Main Branch</option>
                <option value="false">Not Main</option>
            </select>
        </div>
        -->
        <!-- 📄 Page Size -->
        <div>
            @* <select class="form-select" @bind="pageSize"> *@
            <select class="form-select" @onchange="OnPageSizeChanged">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="20">20</option>
            </select>
        </div>

    </div>
    <table class="table">
        <thead>
            <tr>
                <th @onclick="() => Sort(nameof(SpecializationDto.Name))">
                    <span class="@(sortAscending ? "bi bi-arrow-up" : "bi bi-arrow-down")"></span>
                    @SharedDataService.SelectViewLang("Name", "الاسم")
                </th>
                <th @onclick="() => Sort(nameof(SpecializationDto.NameEng))">
                    <span class="@(sortAscending ? "bi bi-arrow-up" : "bi bi-arrow-down")"></span>
                    @SharedDataService.SelectViewLang("Name (Eng.)", "الاسم بالانجليزية")
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @* @foreach (var b in branches) *@
            @foreach (var specialization in ProcessedSpecializations)
            {
                @if (editingSpecializationId == specialization.Id)
                {
                    <tr>
                        <td colspan="3">
                            <EditForm Model="specialization" OnValidSubmit="() => SaveSpecialization(specialization)">
                                <DataAnnotationsValidator/>
                                <div class="row">
                                    <div class="col">
                                        <InputText class="form-control" @bind-Value="specialization.Name" />
                                        <ValidationMessage For="()=> specialization.Name"/>
                                    </div>
                                    <div class="col">
                                        <InputText class="form-control" @bind-Value="specialization.NameEng" />
                                        <ValidationMessage For="()=> specialization.NameEng"/>
                                    </div>
                                    <div class="col">
                                        <button type="submit" class="btn btn-success btn-sm" >Save</button>
                                        <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                                    </div>
                                </div>
                            </EditForm>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>

                        <td>@specialization.Name</td>
                        <td>@specialization.NameEng</td>
                        <td>
                            <button class="btn btn-warning btn-sm"
                                    @onclick="() => EditSpecialization(specialization.Id)">
                                @SharedDataService.SelectViewLang("Edit", "تعديل")
                            </button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => DeleteSpecialization(specialization)">
                                @SharedDataService.SelectViewLang("Delete", "حذف")
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <div class="d-flex justify-content-end align-items-center mt-3">

        <button class="btn btn-sm btn-secondary"
                @onclick="PrevPage"
                disabled="@(pageIndex == 1)">
            Previous
        </button>

        <span class="mx-3">Page @(pageIndex + 1) of @TotalPages @(TotalPages == 1 ? "" : "Pages")</span>

        <button class="btn btn-sm btn-secondary"
                @onclick="NextPage"
                disabled="@(pageIndex >= TotalPages)">
            Next
        </button>

    </div>
</div>

@code {
    private List<SpecializationDto> specializations = new();
    private Guid? editingSpecializationId;
    private Guid companyId;
    private AuthenticationState AuthState;
    protected override async Task OnInitializedAsync()
    {
        AuthState = await ((CustomAuthStateProvider)AuthenticationStateProvider).GetAuthenticationStateAsync();
        companyId = Guid.Parse(AuthState.User.Claims.First(c => c.Type == "company_id").Value);

        await LoadSpecialization();
        
    }
    
    void CreateNew()
    {
        var newItem = new SpecializationDto
        {
            Id = Guid.Empty // IMPORTANT FIX
        };

        specializations.Insert(0, newItem);
        editingSpecializationId= newItem.Id;
    }
    

    void EditSpecialization(Guid id) => editingSpecializationId = id;

    async Task SaveSpecialization(SpecializationDto specialization)
    {
        if (specialization.Id == Guid.Empty)
        {
            Random rnd = new Random();
            // academic.Code = academic.Title.Substring(0, 1) + rnd.Next(100, 999);
            specialization.CompanyId = companyId;

            var bResponse = await SpecializationService.CreateAsync(specialization);
            if (bResponse.IsSuccess)
            {
                //show success
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Specialization has been created successfully", "تم انشاء التخصص العلمي بنجاح"),
                    Type = "success"
                });

            }
            else
            {
                // how fail
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Error has occured, please try again later", "حدث خطأ، الرجاء المحاولة مرة أخرى"),
                    Type = "error"
                });
            }
        }
        else
        {

            var bresponse = await SpecializationService.UpdateAsync(specialization);
            if (bresponse.IsSuccess)
            {
                //show success
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Specialization has been Edited successfully", "تم تعديل التخصص العلمي بنجاح"),
                    Type = "success"
                });
            }
            else
            {
                // show  fail
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Error has occured, please try again later", "حدث خطأ، الرجاء المحاولة مرة أخرى"),
                    Type = "error"
                });
            }
        }

        await LoadSpecialization();
        
        editingSpecializationId = null;
    }

    async Task DeleteSpecialization(SpecializationDto specialization)
    {
        await ModalService.ShowAsync(new ModalOptions
        {
            Title = SharedDataService.SelectViewLang("Confirm Delete", "تأكيد عملية الحذف"),
            Message = SharedDataService.SelectViewLang($"Are you sure you want to delete this Specialization: {specialization.NameEng}?",
                                                        $"هل ترغب فعلا في حذف التخصص العلمي: {specialization.Name}؟"),
            ShowCancel = true,
            OkText = SharedDataService.SelectViewLang("Yes", "نعم"),
            CancelText = SharedDataService.SelectViewLang("No", "لا"),

            OnOk = async () =>
            {
                var brResponse = await SpecializationService.DeleteAsync(specialization.Id);
                if (brResponse.IsSuccess)
                {

                    ToastService.Show(new ToastMessage
                    {
                        Message = SharedDataService.SelectViewLang("Deleted successfully", "تم الحذف بنجاح"),
                        Type = "success"
                    });

                    await LoadSpecialization();
                    await InvokeAsync(StateHasChanged);
                    // var response = await BranchService.GetByCompanyIdAsync(companyId);
                    // if (response.IsSuccess)
                    // {
                    //     branches = response.Data?.ToList() ?? [];
                    //     await InvokeAsync(StateHasChanged);
                    // }
                }
                else
                {
                    ToastService.Show(new ToastMessage
                    {
                        Message = SharedDataService.SelectViewLang("Fail to delete the position", "فشلت عملية الحذف"),
                        Type = "error"
                    });
                }


            }
        });


    }
    
    
    async Task CancelEdit()
    {
        var item = specializations.FirstOrDefault(x => x.Id == editingSpecializationId);

        if (item != null && item.Id != Guid.Empty)
        {
            // existing record → keep it
            var specRes = await SpecializationService.GetByCompanyAsync(companyId, 0, 1000);
            if (specRes.IsSuccess)
            {
                specializations = specRes.Data?.Data?.ToList() ?? [];
            }
        }
        else
        {
            // new record → remove it
            specializations.Remove(item);
        }

        editingSpecializationId= null;
    }

    #region Table Helpers


    // Searching
    private string searchText = "";

    // Sorting
    private string sortColumn = nameof(SpecializationDto.Name);
    private bool sortAscending = true;

    // Pagination
    private int pageSize = 5;
    private int pageIndex = 0;
    private async Task LoadSpecialization()
    {
        // var request = new PaginationRequest(pageIndex, pageSize, searchText);

        var response = await SpecializationService.GetByCompanyAsync(companyId, pageIndex, pageSize);//,searchText);

        if (response.IsSuccess)
        {
            // var result = response.Data!.Data;

            // branches = result.Data.ToList();
            specializations = response.Data?.Data.ToList() ?? [];
            // TotalPages = (int)response.Data!.Count;
            TotalPages = (int)Math.Ceiling(response.Data!.Count / (double)pageSize);
        }
    }
    async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        pageSize = int.Parse(e.Value!.ToString()!);
        pageIndex = 0;
        await LoadSpecialization();
    }
    private IEnumerable<SpecializationDto> ProcessedSpecializations =>
    specializations
        // 🔍 Search
        .Where(b =>
            string.IsNullOrWhiteSpace(searchText) ||
            (b.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (b.NameEng?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        )

        
        // 🎯 Filter
        // .Where(b =>
        //     filterMainBranch == null || b.IsMainBranch == filterMainBranch
        // )

        // 🔃 Sorting
        .OrderByDynamic(sortColumn, sortAscending)

        // 📄 Pagination
        .Skip((pageIndex) * pageSize)
        .Take(pageSize);



    // Filtering example
    private bool? filterMainBranch = null;
    // private long totalCount = 0;
    private int TotalPages = 1;
    // private int TotalPages =>
    // (int)Math.Ceiling(
    //     totalCount/ (double)pageSize);

    async Task NextPage()
    {
        // if (currentPage < TotalPages)
        //     currentPage++;

        if (pageIndex < TotalPages - 1)
        {
            pageIndex++;
            await LoadSpecialization();
        }
    }

    async Task PrevPage()
    {
        // if (pageIndex > 1)
        //     pageIndex--;
        
        if (pageIndex > 0)
        {
            pageIndex--;
            await LoadSpecialization();
        }
    }

    void Sort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }
    #endregion Table helpers
}
