@if (!AuthState.User.Claims.Any(c => c.Value == PermissionList.EmployeePermissions.View))
{
    <div class="alert alert-warning">
        <span>@SharedDataService.SelectViewLang("You don't have permissions to view this page","ليس لديك الصلاحيات لعرض هذه الصفحة")</span>
    </div>

    return;
}

<!-- Branches -->
<h5>@SharedDataService.SelectViewLang("Employees Management", "ادارة الموظفين")</h5>

@* <button class="btn btn-sm btn-primary mb-2" @onclick="CreateNew">+ Add Branch</button> *@
<button class="btn btn-primary mb-3"
        @onclick="CreateNew"
        disabled=@(!AuthState.User.Claims.Any(c => c.Value == $"{PermissionList.EmployeePermissions.Create}") ? true : false)>
    <i class="bi bi-file-earmark-plus-fill"></i> @(SharedDataService.Language == "Ar" ? "إضافة جديد" : "Create New")
</button>

<div class="card p-3 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <!--

        Export to xls and pdf
        <div class="d-flex gap-2">

            <button class="btn btn-success btn-sm" @onclick="ExportToExcel">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </button>

            <button class="btn btn-danger btn-sm" @onclick="ExportToPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </button>

        </div>
        -->
        <!-- 🔍 Search -->
        <div>
            <input class="form-control"
                   placeholder="Search..."
                   @bind="searchText" />
        </div>

        <!--

        🎯 Filter
        <div class="col-md-3">
            <select class="form-select" @bind="filterMainBranch">
                <option value="">All</option>
                <option value="true">Main Branch</option>
                <option value="false">Not Main</option>
            </select>
        </div>
        -->
        <!-- 📄 Page Size -->
        <div>
            @* <select class="form-select" @bind="pageSize"> *@
            <select class="form-select" @onchange="OnPageSizeChanged">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="20">20</option>
            </select>
        </div>

    </div>
    <table class="table">
        <thead>
            <tr>
                <th>@SharedDataService.SelectViewLang("EmployeeNo", "الرقم الوظيفي")</th>
                <th @onclick="() => Sort(nameof(EmployeeDto.FullName))">
                    <span class=@(sortAscending)?"bi bi-file-earmark-plus-fill":"bi bi-file-earmark-plus")></span>
                    @SharedDataService.SelectViewLang("Name", "الاسم")
                </th>
                <th>@SharedDataService.SelectViewLang("DOB", "الميلاد")</th>
                <th>@SharedDataService.SelectViewLang("Email", "الايميل")</th>
                <th>@SharedDataService.SelectViewLang("Phone", "الهاتف")</th>
                <th>@SharedDataService.SelectViewLang("Hire Date", "تاريخ التعيين")</th>
                <th @onclick="() => Sort(nameof(EmployeeDto.PositionName))">@SharedDataService.SelectViewLang("Position", "المسمى الوظيفي")</th>
                @* <th>@SharedDataService.SelectViewLang("Location","الموقع")</th> *@
                <th></th>
            </tr>
        </thead>
        <tbody>
            @* @foreach (var b in branches) *@
            @foreach (var emp in ProcessedBranches)
            {
                <tr>
                    <!--
                    @if (editingEmployeeId == b.Id)
                    {
                        <td><InputText class="form-control" @bind-Value="b.Name" /></td>
                        <td><InputText class="form-control" @bind-Value="b.NameEng" /></td>
                        <td><InputText class="form-control" @bind-Value="b.Phone" /></td>
                        <td><InputText class="form-control" @bind-Value="b.Email" /></td>
                        <td><InputText class="form-control" @bind-Value="b.Location" /></td>
                        <td><InputNumber class="form-control" @bind-Value="b.Longitude" /></td>
                        <td><InputNumber class="form-control" @bind-Value="b.Latitude" /></td>
                        <td><InputCheckbox class="form-check-input" @bind-Value="b.IsMainBranch" /></td>
                        <td>
                            <button class="btn btn-success btn-sm" @onclick="() => SaveBranch(b)">Save</button>
                            <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                        </td>
                    }
                    else
                    {
                    }
                        -->
                    

                    <td>@emp.EmployeeNo</td>
                    <td>@emp.FullName</td>
                    <td>@emp.DateOfBirth.ToString("yyyy/MM/dd")</td>
                    <td>@emp.Email</td>
                    <td>@emp.Phone</td>
                    <td>@emp.HireDate.ToString("yyyy/MM/dd")</td>
                    <td>@(SharedDataService.SelectViewLang(
                        positions.FirstOrDefault(p => p.Id == emp.PositionId)?.TitleEng ?? "", 
                        positions.FirstOrDefault(p => p.Id == emp.PositionId)?.Title?? ""))
                    </td>
                    
                    <td>
                        <a class="btn btn-warning btn-sm" href="Employee/Employee/view/@emp.Id">@SharedDataService.SelectViewLang("View", "عرض")</a>
                        <a class="btn btn-warning btn-sm" href="Employee/Employee/QR/@emp.Id">@SharedDataService.SelectViewLang("View QR", "QR Code")</a>
                        <button class="btn btn-warning btn-sm" 
                            @onclick="() => EditBranch(emp.Id)"
                                disabled=@(!AuthState.User.Claims.Any(c => c.Value == PermissionList.EmployeePermissions.Edit))>
                            @SharedDataService.SelectViewLang("Edit", "تعديل")
                            </button>
                        <button 
                            class="btn btn-danger btn-sm" 
                            @onclick="() => DeleteEmployee(emp)"
                                disabled=@(!AuthState.User.Claims.Any(c => c.Value == PermissionList.EmployeePermissions.Delete))>
                            @SharedDataService.SelectViewLang("Delete", "حذف")
                        </button>
                    </td>

                    

                </tr>
            }
        </tbody>
    </table>
    <div class="d-flex justify-content-end align-items-center mt-3">

        <button class="btn btn-sm btn-secondary"
                @onclick="PrevPage"
                disabled="@(pageIndex == 1)">
            Previous
        </button>

        <span class="mx-3">Page @(pageIndex + 1) of @TotalPages @(TotalPages == 1 ? "" : "Pages")</span>

        <button class="btn btn-sm btn-secondary"
                @onclick="NextPage"
                disabled="@(pageIndex >= TotalPages)">
            Next
        </button>

    </div>
</div>

