@layout LandingPageLayout
@page "/Employee/Employee/view/{Id:guid?}"
@using AlAfkarERP.Shared.Dtos
@using AlAfkarERP.Shared.Pages.Features.Employees.Services
@using SharedWithUI.Employees.Dtos

@inject IEmployeeService EmployeeService
@inject ApiConfig ApiConfig

<main class="d-flex justify-content-center align-items-center" style="height: 100vh;">
   
    @* <main style="margin-top: 80px;"> *@
    @if (employee != null)
    {
        <div class="card" style="width: 18rem;margin-top:100px;">
            <img src="@(string.IsNullOrEmpty(employee?.PhotoUrl)
                                                                 ? "_content/AlAfkarERP.Shared/images/empPlaceholder.png"
                                                                 : (employee.PhotoUrl.Contains("data:")
                                                                     ? employee.PhotoUrl
                                                                     : $"{ApiConfig.BaseURL}/Images/Employees/{employee.PhotoUrl}"))"
                class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title text-center">@(employee?.FirstName ?? "") @employee.MiddleName @employee.LastName</h5>
                <p class="card-text text-center">@employee.NationalId</p>
                <p class="card-text text-center">@employee.Nationality</p>
                @* <a href="#" class="btn btn-primary">Go somewhere</a> *@
            </div>
        </div>
    }
    else
    {
        <div class="card" style="width: 18rem;margin-top:100px;">
            <img src="_content/AlAfkarERP.Shared/images/empPlaceholder.png" class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title">غير معروف</h5>
                <p class="card-text"></p>
                @* <a href="#" class="btn btn-primary">Go somewhere</a> *@
            </div>
        </div>
    }
</main>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private EmployeeDto? employee;
    protected override async Task OnInitializedAsync()
    {

        if (Id.HasValue)
        {
            var empRes = await EmployeeService.GetByIdAsync(Id.Value);
            if (empRes.IsSuccess)
            {
                employee = empRes.Data ?? null;
            }
        }
    }
}
