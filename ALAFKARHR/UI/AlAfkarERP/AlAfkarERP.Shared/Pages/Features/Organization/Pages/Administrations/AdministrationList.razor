@page "/Organization/Administration/List"
@using AlAfkarERP.Shared.Pages.Features.Auth.Dtos
@using AlAfkarERP.Shared.Pages.Features.Company.Dtos
@using AlAfkarERP.Shared.Pages.Features.Company.Services
@* @using AlAfkarERP.Shared.Pages.Reuable *@
@using AlAfkarERP.Shared.Pages.Reuable
@using AlAfkarERP.Shared.Pages.Reuable2
@using AlAfkarERP.Shared.Services.Auth
@using AlAfkarERP.Shared.Utilities
@using Microsoft.AspNetCore.Components.Authorization


@inject IBranchService BranchService
@inject IAdministrationService AdministrationService
@inject IAuthService AuthService
@inject ToastService ToastService
@inject ModalService ModalService

@inject AuthenticationStateProvider AuthenticationStateProvider


@inject NavigationManager NavigationManager
@inject SharedDataService SharedDataService


<!-- Branches -->
<h5>@SharedDataService.SelectViewLang("Administrations Management", "ادارة الإدارات")</h5>

@* <button class="btn btn-sm btn-primary mb-2" @onclick="CreateNew">+ Add Branch</button> *@
<div>
    <div class="mb-3">
        <label for="Products" class="form-label">@(SharedDataService.Language == "Ar" ? "اختر الفرع" : "Select Branch")</label>
        <AutoCompleteComponent TItem="BranchDto"
                               Items="branches"
                               ItemText='(p=> SharedDataService.Language=="Ar"? p.Name:p.NameEng)'
                               OnSelected="OnBranchSelected">
        </AutoCompleteComponent>
    </div>
</div>
<button class="btn btn-primary mb-3"
        @onclick="CreateNew"
        disabled=@(!AuthState.User.Claims.Any(c => c.Value == $"{PermissionList.BrandPermissions.Create}") ? true : false)>
    <i class="bi bi-file-earmark-plus-fill"></i> @(SharedDataService.Language == "Ar" ? "إضافة جديد" : "Create New")
</button>

<div class="card p-3 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <!--

        Export to xls and pdf
        <div class="d-flex gap-2">

            <button class="btn btn-success btn-sm" @onclick="ExportToExcel">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </button>

            <button class="btn btn-danger btn-sm" @onclick="ExportToPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </button>

        </div>
        -->
        <!-- 🔍 Search -->
        <div>
            <input class="form-control"
                   placeholder="Search..."
                   @bind="searchText" />
        </div>

        <!--

        🎯 Filter
        <div class="col-md-3">
            <select class="form-select" @bind="filterMainBranch">
                <option value="">All</option>
                <option value="true">Main Branch</option>
                <option value="false">Not Main</option>
            </select>
        </div>
        -->
        <!-- 📄 Page Size -->
        <div>
            @* <select class="form-select" @bind="pageSize"> *@
            <select class="form-select" @onchange="OnPageSizeChanged">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="20">20</option>
            </select>
        </div>

    </div>
    <table class="table">
        <thead>
            <tr>
                <th @onclick="() => Sort(nameof(AdministrationDto.Name))"><span class=@(sortAscending)?"bi bi-file-earmark-plus-fill":"bi bi-file-earmark-plus")></span> Name</th>
                <th @onclick="() => Sort(nameof(AdministrationDto.NameEng))">NameEng</th>
                @* <th @onclick="() => Sort(nameof(AdministrationDto.BranchId))">Branch</th> *@
                <th @onclick="() => Sort(nameof(AdministrationDto.ManagerId))">Manager</th>
                <th>@SharedDataService.SelectViewLang("IsActive?", "فعال؟")</th>
            <th></th>
            </tr>
        </thead>
        <tbody>
            @* @foreach (var b in branches) *@
            @foreach (var admin in ProcessedAdministrations)
            {
                <tr>
                    @if (editingAdministration == admin.Id)
                    {

                        <td><InputText class="form-control" @bind-Value="admin.Name" /></td>
                        <td><InputText class="form-control" @bind-Value="admin.NameEng" /></td>
                        <td>
                            <div class="mb-3">
                                @* <label for="Products" class="form-label">@(SharedDataService.Language == "Ar" ? "مدير الادارة" : "Manager")</label> *@
                                <AutoCompleteComponent TItem="UserDto"
                                                       Items="users"
                                                       PlaceHolder="search manager ..."
                                                       ItemText='(p=> p.UserName)'
                                                       OnSelected="OnUserSelected">
                                </AutoCompleteComponent>
                            </div>
                        </td>
                        <td><InputCheckbox class="form-check-input" @bind-Value="admin.IsActive" /></td>
                        @* <td><InputText class="form-control" @bind-Value="admin.BranchId.ToString()" /></td> *@
                        @* <td><InputText class="form-control" @bind-Value="admin.ManagerId.ToString()" /></td> *@
                        <td>
                            <button class="btn btn-success btn-sm" @onclick="async () => SaveAdministration(admin)">Save</button>
                            <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                        </td>
                    }
                    else
                    {
                        <td>@admin.Name</td>
                        <td>@admin.NameEng</td>
                        @* <td>@admin.BranchId</td> *@
                        <td>@(users.FirstOrDefault(u => u.Id == admin.ManagerId)?.UserName ?? "")</td>
                        <td>@admin.IsActive</td>
                        <td>
                            <button class="btn btn-warning btn-sm" @onclick="() => EditAdministration(admin)">@SharedDataService.SelectViewLang("Edit", "تعديل")</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteAdministration(admin)">@SharedDataService.SelectViewLang("Delete", "حذف")</button>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
    <div class="d-flex justify-content-end align-items-center mt-3">

        <button class="btn btn-sm btn-secondary"
                @onclick="PrevPage"
                disabled="@(pageIndex == 1)">
            Previous
        </button>

        <span class="mx-3">Page @(pageIndex + 1) of @TotalPages @(TotalPages == 1 ? "" : "Pages")</span>

        <button class="btn btn-sm btn-secondary"
                @onclick="NextPage"
                disabled="@(pageIndex >= TotalPages)">
            Next
        </button>

    </div>
</div>

@code {
    private List<BranchDto> branches = new();
    private List<AdministrationDto> administrations = new();
    private List<UserDto> users = [];
    private UserDto manager = new();
    private Guid? editingAdministration;
    private Guid companyId;
    private AuthenticationState AuthState;
    protected override async Task OnInitializedAsync()
    {
        AuthState = await ((CustomAuthStateProvider)AuthenticationStateProvider).GetAuthenticationStateAsync();
        companyId = Guid.Parse(AuthState.User.Claims.First(c => c.Type == "company_id").Value);

        var userResponse = await AuthService.GetAsync(0, 100);
        if (userResponse.IsSuccess)
        {
            users = userResponse.Data?.Data?.ToList() ?? [];
        }

        // await LoadBranches();
        var branchResponse = await BranchService.GetByCompanyIdAsync(companyId, 0, 1000);
        if (branchResponse.IsSuccess)
        {
            branches = branchResponse.Data?.Data?.ToList() ?? [];
        }
    }
    BranchDto selectedBranch = new();
    private async Task OnBranchSelected(BranchDto branch)
    {
        selectedBranch = branch;
        if (selectedBranch != null && selectedBranch.Id != Guid.Empty)
        {
            

            await LoadAdministrations();
            StateHasChanged();
        }
    }
    private async Task OnUserSelected(UserDto user)
    {
        manager = user;
        if (manager != null && manager.Id != Guid.Empty)
        {

            // await LoadAdministrations();
        }
        StateHasChanged();
    }
    // Branch
    async Task CreateNew()
    {

        if (selectedBranch == null || selectedBranch.Id == Guid.Empty)
        {
            await ModalService.ShowAsync(new ModalOptions
            {
                Title = SharedDataService.SelectViewLang("Create New", "إضافة"),
                Message = SharedDataService.SelectViewLang($"Please select branch first", $"يرجى اختيار الفرع اولا"),
                // ShowCancel = true,
                // OkText = SharedDataService.SelectViewLang("Yes", "نعم"),
                // CancelText = SharedDataService.SelectViewLang("No", "لا"),

                OnOk = async () =>
                {



                }
            });

            return;
        }
        var newItem = new AdministrationDto();
        administrations.Insert(0, newItem);
        editingAdministration = newItem.Id;
    }

    void EditAdministration(AdministrationDto admin)
    {

        editingAdministration = admin.Id;
    }

    async Task SaveAdministration(AdministrationDto admin)
    {
        if (admin.Id == Guid.Empty)
        {
            Random rnd = new Random();
            admin.Code = admin.NameEng.Substring(0, 1) + rnd.Next(100, 999);
            admin.CompanyId = companyId;
            admin.BranchId = selectedBranch.Id;
            admin.ManagerId = manager.Id != Guid.Empty ? manager.Id : null;
            var bResponse = await AdministrationService.CreateAsync(admin);
            if (bResponse.IsSuccess)
            {
                //show success
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Administration has been created successfully", "تم انشاء الإدارة بنجاح"),
                    Type = "success"
                });

            }
            else
            {
                // how fail
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Error has occured, please try again later", "حدث خطأ، الرجاء المحاولة مرة أخرى"),
                    Type = "error"
                });
            }
        }
        else
        {
            //Update
            if (manager != null && manager.Id != Guid.Empty && admin.ManagerId != manager.Id)
            {
                admin.ManagerId = manager.Id;
            }
            var bresponse = await AdministrationService.UpdateAsync(admin);
            if (bresponse.IsSuccess)
            {
                //show success
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Administration has been Edited successfully", "تم تعديل الإدارة بنجاح"),
                    Type = "success"
                });
            }
            else
            {

                // show  fail
                ToastService.Show(new ToastMessage
                {
                    Message = SharedDataService.SelectViewLang("Error has occured, please try again later", "حدث خطأ، الرجاء المحاولة مرة أخرى"),
                    Type = "error"
                });
            }
        }

        await LoadAdministrations();
        // var response = await BranchService.GetByCompanyIdAsync(companyId);
        // if (response.IsSuccess)
        // {
        //     branches = response.Data?.ToList() ?? [];
        // }
        editingAdministration = null;
        StateHasChanged();
    }

    async Task DeleteAdministration(AdministrationDto admin)
    {
        await ModalService.ShowAsync(new ModalOptions
        {
            Title = SharedDataService.SelectViewLang("Confirm Delete", "تأكيد عملية الحذف"),
            Message = SharedDataService.SelectViewLang($"Are you sure you want to delete this administration: {admin.NameEng}?", $"هل ترغب فعلا في حذف الإدارة: {admin.Name}؟"),
            ShowCancel = true,
            OkText = SharedDataService.SelectViewLang("Yes", "نعم"),
            CancelText = SharedDataService.SelectViewLang("No", "لا"),

            OnOk = async () =>
            {
                var adminResponse = await AdministrationService.DeleteAsync(admin.Id);
                if (adminResponse.IsSuccess)
                {

                    ToastService.Show(new ToastMessage
                    {
                        Message = SharedDataService.SelectViewLang("Deleted successfully", "تم الحذف بنجاح"),
                        Type = "success"
                    });

                    await LoadAdministrations();
                    await InvokeAsync(StateHasChanged);
                    // var response = await BranchService.GetByCompanyIdAsync(companyId);
                    // if (response.IsSuccess)
                    // {
                    //     branches = response.Data?.ToList() ?? [];
                    //     await InvokeAsync(StateHasChanged);
                    // }
                }
                else
                {
                    ToastService.Show(new ToastMessage
                    {
                        Message = SharedDataService.SelectViewLang("Fail to delete the Administration", "فشلت عملية الحذف"),
                        Type = "error"
                    });
                }


            }
        });


    }
    void CancelEdit()
    {
        if (editingAdministration == null || editingAdministration == Guid.Empty)
        {
            var brToRemove = administrations.FirstOrDefault(b => b.Id == editingAdministration);
            if (brToRemove != null)
            {
                administrations.Remove(brToRemove);
            }

        }

        editingAdministration = null;
    }

    #region Table Helpers


    // Searching
    private string searchText = "";

    // Sorting
    private string sortColumn = nameof(BranchDto.Name);
    private bool sortAscending = true;

    // Pagination
    private int pageSize = 5;
    private int pageIndex = 0;
    private async Task LoadAdministrations()
    {
        TotalPages = 0;
        if (selectedBranch == null || selectedBranch.Id == Guid.Empty)
        {
            administrations = [];
            return;
        }


        var response = await AdministrationService.GetByBranchAsync(selectedBranch.Id, pageIndex, pageSize);//,searchText);

        if (response.IsSuccess)
        {
            // var result = response.Data!.Data;

            // branches = result.Data.ToList();
            administrations = response.Data?.Data.ToList() ?? [];
            // TotalPages = (int)response.Data!.Count;
            TotalPages = (int)Math.Ceiling(response.Data!.Count / (double)pageSize);
        }
    }
    async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        pageSize = int.Parse(e.Value!.ToString()!);
        pageIndex = 0;
        await LoadAdministrations();
    }
    private IEnumerable<AdministrationDto> ProcessedAdministrations =>
    administrations
        // 🔍 Search
        .Where(b =>
            string.IsNullOrWhiteSpace(searchText) ||
            (b.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (b.NameEng?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        // (b.Email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        )

        // 🎯 Filter
        // .Where(b =>
        //     filterMainBranch == null || b.IsMainBranch == filterMainBranch
        // )

        // 🔃 Sorting
        .OrderByDynamic(sortColumn, sortAscending)

        // 📄 Pagination
        .Skip((pageIndex) * pageSize)
        .Take(pageSize);



    // Filtering example
    private bool? filterMainBranch = null;
    // private long totalCount = 0;
    private int TotalPages = 1;
    // private int TotalPages =>
    // (int)Math.Ceiling(
    //     totalCount/ (double)pageSize);

    async Task NextPage()
    {
        // if (currentPage < TotalPages)
        //     currentPage++;

        if (pageIndex < TotalPages - 1)
        {
            pageIndex++;
            await LoadAdministrations();
        }
    }

    async Task PrevPage()
    {
        // if (pageIndex > 1)
        //     pageIndex--;
        
        if (pageIndex > 0)
        {
            pageIndex--;
            await LoadAdministrations();
        }
    }

    void Sort(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }
    #endregion Table helpers
}
