// Blazor Page: Company Details with Inline Editing (No Modals)
@page "/companies/{Id:guid}"
@using AlAfkarERP.Shared.Pages.Features.Company.Dtos
@using AlAfkarERP.Shared.Pages.Features.Company.Services

@inject ICompanyService CompanyService
@inject IBranchService BranchService
@inject IAdministrationService AdministrationService
@inject IDepartmentService DepartmentService

<h3 class="mb-3">Company Details</h3>

@if (company == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card p-3 mb-3">
        <h4>@company.Name</h4>
        <div class="text-muted">@company.Code | @company.Currency</div>
    </div>

    <!-- Branches -->
    <div class="card p-3 mb-3">
        <h5>Branches</h5>

        <button class="btn btn-sm btn-primary mb-2" @onclick="AddBranchRow">+ Add Branch</button>

        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Location</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in branches)
                {
                    <tr>
                        @if (editingBranchId == b.Id)
                        {
                            <td><InputText class="form-control" @bind-Value="b.Name" /></td>
                            <td><InputText class="form-control" @bind-Value="b.Location" /></td>
                            <td>
                                <button class="btn btn-success btn-sm" @onclick="() => SaveBranch(b)">Save</button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                            </td>
                        }
                        else
                        {
                            <td>@b.Name</td>
                            <td>@b.Location</td>
                            <td>
                                <button class="btn btn-warning btn-sm" @onclick="() => EditBranch(b.Id)">Edit</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteBranch(b.Id)">Delete</button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Administrations -->
    <div class="card p-3 mb-3">
        <h5>Administrations</h5>

        <button class="btn btn-sm btn-primary mb-2" @onclick="AddAdministrationRow">+ Add Administration</button>

        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Branch</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in administrations)
                {
                    <tr>
                        @if (editingAdministrationId == a.Id)
                        {
                            <td><InputText class="form-control" @bind-Value="a.Name" /></td>
                            <td>
                                <select class="form-select" @bind="a.BranchId">
                                    @foreach (var b in branches)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn btn-success btn-sm" @onclick="() => SaveAdministration(a)">Save</button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                            </td>
                        }
                        else
                        {
                            <td>@a.Name</td>
                            @* <td>@a.BranchName</td> *@
                            <td>
                                <button class="btn btn-warning btn-sm" @onclick="() => EditAdministration(a.Id)">Edit</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteAdministration(a.Id)">Delete</button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Departments -->
    <div class="card p-3">
        <h5>Departments</h5>

        <button class="btn btn-sm btn-primary mb-2" @onclick="AddDepartmentRow">+ Add Department</button>

        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Administration</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in departments)
                {
                    <tr>
                        @if (editingDepartmentId == d.Id)
                        {
                            <td><InputText class="form-control" @bind-Value="d.Name" /></td>
                            <td>
                                <select class="form-select" @bind="d.AdministrationId">
                                    @foreach (var a in administrations)
                                    {
                                        <option value="@a.Id">@a.Name</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn btn-success btn-sm" @onclick="() => SaveDepartment(d)">Save</button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                            </td>
                        }
                        else
                        {
                            <td>@d.Name</td>
                            @* <td>@d.AdministrationName</td> *@
                            <td>
                                <button class="btn btn-warning btn-sm" @onclick="() => EditDepartment(d.Id)">Edit</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteDepartment(d.Id)">Delete</button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private CompanyDto? company;
    private List<BranchDto> branches = new();
    private List<AdministrationDto> administrations = new();
    private List<DepartmentDto> departments = new();

    private Guid? editingBranchId;
    private Guid? editingAdministrationId;
    private Guid? editingDepartmentId;

    protected override async Task OnInitializedAsync()
    {
        var comResult = await CompanyService.GetByIdAsync(Id);
        if (comResult.IsSuccess)
        {
            company = comResult.Data;
        }
        var branchResponse = await BranchService.GetByCompanyIdAsync(Id);
        if (branchResponse.IsSuccess)
        {
            branches = branchResponse.Data?.ToList() ?? [];
        }
    }

    // Branch
    void AddBranchRow()
    {
        var newItem = new BranchDto();
        branches.Insert(0, newItem);
        editingBranchId = newItem.Id;
    }

    void EditBranch(Guid id) => editingBranchId = id;

    async Task SaveBranch(BranchDto b)
    {
        if (b.Id == Guid.Empty)
            await BranchService.CreateAsync(b);
        else
            await BranchService.UpdateAsync(b);

        var response = await BranchService.GetByCompanyIdAsync(Id);
        if(response.IsSuccess)
        {
            branches = response.Data?.ToList() ?? [];
        }
        editingBranchId = null;
    }

    async Task DeleteBranch(Guid id)
    {
        await BranchService.DeleteAsync(id);
        var response = await BranchService.GetByCompanyIdAsync(Id);
        if (response.IsSuccess)
        {
            branches = response.Data?.ToList() ?? [];
        }
    }

    // Administration
    void AddAdministrationRow()
    {
        var newItem = new AdministrationDto();
        administrations.Insert(0, newItem);
        editingAdministrationId = newItem.Id;
    }

    void EditAdministration(Guid id) => editingAdministrationId = id;

    async Task SaveAdministration(AdministrationDto a)
    {
        await AdministrationService.CreateAsync(a);
        var admResponse= await AdministrationService.GetByBranchAsync(a.BranchId);
        if (admResponse.IsSuccess)
        {
            administrations = admResponse.Data?.ToList() ?? [];
        }
        editingAdministrationId = null;
    }

    async Task DeleteAdministration(Guid id)
    {
        await AdministrationService.DeleteAsync(id);
        administrations.RemoveAll(x => x.Id == id);
    }

    // Department
    void AddDepartmentRow()
    {
        var newItem = new DepartmentDto();
        departments.Insert(0, newItem);
        editingDepartmentId = newItem.Id;
    }

    void EditDepartment(Guid id) => editingDepartmentId = id;

    async Task SaveDepartment(DepartmentDto d)
    {
        await DepartmentService.CreateAsync(d);
        var deptResponse = await DepartmentService.GetByAdministrationAsync(d.AdministrationId);
        if (deptResponse.IsSuccess)
        {
            departments = deptResponse.Data?.ToList() ?? [];
        }
        editingDepartmentId = null;
    }

    async Task DeleteDepartment(Guid id)
    {
        await DepartmentService.DeleteAsync(id);
        departments.RemoveAll(x => x.Id == id);
    }

    void CancelEdit()
    {
        editingBranchId = editingAdministrationId = editingDepartmentId = null;
    }
}
