@using AlAfkarERP.Shared.Utilities
@inject SharedDataService SharedDataService
@inject NavigationManager NavigationManager

<div class="bg-dark text-white d-flex flex-column p-2" style="width: 250px;">

    <!-- Logo -->
    <div class="text-center mb-3">
        <h5 class="fw-bold">ERP System</h5>
    </div>

    <!-- Menu -->
    <ul class="nav nav-pills flex-column">

        <li class="nav-item">
            <NavLink href="/" class="nav-link text-white-50" Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-2"></i>
                @SharedDataService.SelectViewLang("Home", "الرئيسية")
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink href="/AdminDashboard" class="nav-link text-white-50">
                <i class="bi bi-speedometer2 me-2"></i>
                @SharedDataService.SelectViewLang("Control Panel", "لوحة التحكم")
            </NavLink>
        </li>

        <li class="nav-item">
            <NavLink href="/Organization/Dashboard" class="nav-link text-white-50">
                <i class="bi bi-diagram-3 me-2"></i>
                @(SharedDataService.SelectViewLang("Organizational Structure", "الهيكل التنظيمي"))
            </NavLink>
        </li>

        
        <li class="nav-item">
            <NavLink href="/Employee/Dashboard" class="nav-link text-white-50">
                <i class="bi bi-people me-2"></i>
                @(SharedDataService.SelectViewLang("Human Resource", "الموارد البشرية"))
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink href="/Warehouse/Dashboard" class="nav-link text-white">
                <i class="bi bi-box-seam me-2"></i>
                @(SharedDataService.SelectViewLang("Warehouses", "المستودعات"))
            </NavLink>
        </li>
        
        <li class="nav-item ms-3">
            <NavLink href="/Warehouse/Product/Dashboard" class="nav-link text-white">
                <i class="bi bi-tags me-2"></i>
                @(SharedDataService.SelectViewLang("Products Management", "ادارة المنتجات"))
            </NavLink>
            <ul class="nav nav-pills flex-column ms-3">
                <li class="nav-item ms-3">
                    <NavLink href="/Catalog/Product/List" class="nav-link text-white">
                        <i class="bi bi-bag me-2"></i>
                        @(SharedDataService.SelectViewLang("Products", "المنتجات"))
                    </NavLink>
                </li>
                
                <li class="nav-item ms-3">
                    <NavLink href="/Catalog/Variant/List" class="nav-link text-white">
                        <i class="bi bi-bag me-2"></i>
                        @(SharedDataService.SelectViewLang("Product Options", "خيارات المنتج"))
                    </NavLink>
                </li>
                
                <li class="nav-item ms-3">
                    <NavLink href="/Warehouse/Product/Brand/List" class="nav-link text-white">
                        <i class="bi bi-award me-2"></i>
                        @(SharedDataService.SelectViewLang("Brand", "العلامة التجارية"))
                    </NavLink>
                </li>
                <li class="nav-item ms-3">
                    <NavLink href="/Warehouse/Product/Category/List" class="nav-link text-white">
                        <i class="bi bi-diagram-3 me-2"></i>
                        @(SharedDataService.SelectViewLang("Categories", "الأصناف"))
                    </NavLink>
                </li>
                <li class="nav-item ms-3">
                    <NavLink href="/Warehouse/Product/Unit/List" class="nav-link text-white">
                        <i class="bi bi-rulers me-2"></i>
                        @(SharedDataService.SelectViewLang("Units", "الوحدات"))
                    </NavLink>
                </li>

            </ul>
        </li>
        
        <li class="nav-item ms-3">
            <NavLink href="/Warehouse/Inventory/Dashboard" class="nav-link text-white">
                <i class="bi bi-boxes me-2"></i>
                @(SharedDataService.SelectViewLang("Inventory Management", "ادارة المخزون"))
            </NavLink>
        </li>


        <li class="nav-item">
            <NavLink href="/Auth/Dashboard" class="nav-link text-white-50">
                <i class="bi bi-shield-lock me-2"></i>
                @SharedDataService.SelectViewLang("Security Management", "إدارة الآمان")
            </NavLink>
        </li>

    </ul>

</div>

@code {
    protected override void OnInitialized()
    {
        SharedDataService.OnChange1 += HandleChangeAsync;
    }

    private async Task HandleChangeAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SharedDataService.OnChange1 -= HandleChangeAsync;
    }
}