name: dockercompose8416443178977204518
services:
  alafkar_hr_db:
    container_name: hrdb
    environment:
      POSTGRES_DB: HRDb
      POSTGRES_PASSWORD: postgres
      POSTGRES_USER: postgres
    image: postgres:17
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    restart: always
    volumes:
      - type: volume
        source: postgres_alafkar_hr_db
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: dockercompose8416443178977204518_default
volumes:
  postgres_alafkar_hr_db:
    name: dockercompose8416443178977204518_postgres_alafkar_hr_db